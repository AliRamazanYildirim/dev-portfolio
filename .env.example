NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# Datenbank  
# App-Verkehr (gebündelt)
DATABASE_URL=

# Migration/CLI (direct)
DIRECT_URL=

#MongoDB (Datenbankverbindung)
MONGODB_URI=mongodb+srv://.............

# Database
DATABASE_URL=
DIRECT_URL=

# Cloudinary (Für die Bildverwaltung)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# EmailJS (Für das aktuelle Kontaktformular)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Admin Authentication (Für das Admin-Panel)
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=
# Generate with: bun run scripts/hash-password.ts "YourStrongPassword"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# Admin Login Security (Rate Limit + Lockout)
LOGIN_IP_WINDOW_LIMIT=20
LOGIN_IP_WINDOW_SECONDS=600
LOGIN_EMAIL_IP_WINDOW_LIMIT=8
LOGIN_EMAIL_IP_WINDOW_SECONDS=600
LOGIN_FAILED_LOCK_LIMIT=10
LOGIN_FAILED_LOCK_WINDOW_SECONDS=900
LOGIN_BACKOFF_BASE_SECONDS=2
LOGIN_BACKOFF_MAX_SECONDS=120
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_TIMEOUT_MS=8000
NEXT_PUBLIC_TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=

# Invoice Email Credentials (Für das Versenden von Rechnungen per Email)
EMAIL_USER=
EMAIL_PASS=

# Contact Email Security (Rate-Limit + Turnstile + Delivery Guard)
SEND_EMAIL_IP_WINDOW_LIMIT=5
SEND_EMAIL_IP_WINDOW_SECONDS=600
SEND_EMAIL_FINGERPRINT_WINDOW_LIMIT=3
SEND_EMAIL_FINGERPRINT_WINDOW_SECONDS=600
SEND_EMAIL_TURNSTILE_ENABLED=false
SEND_EMAIL_TURNSTILE_SECRET_KEY=
SEND_EMAIL_TURNSTILE_VERIFY_TIMEOUT_MS=8000
SEND_EMAIL_MAX_CONCURRENT=2
SEND_EMAIL_MAX_QUEUE_SIZE=50
SEND_EMAIL_CIRCUIT_FAILURE_THRESHOLD=5
SEND_EMAIL_CIRCUIT_OPEN_SECONDS=60

# Next.js Base URL (für API-Aufrufe)
NEXTAUTH_URL=
