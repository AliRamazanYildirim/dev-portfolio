# ZAP Authenticated Scan Credentials
#
# Lokal kullanım için kopyala:
#   cp .env.zap.example .env.zap
#
# Email + Password .env'deki ADMIN_EMAIL ve ADMIN_PASSWORD_HASH ile eşleşmeli.
# Yeni admin için:
#   bun run scripts/hash-password.ts "YourPassword"
#   .env'e: ADMIN_EMAIL=... ADMIN_PASSWORD_HASH=$2b$...
#   .env.zap'a: ZAP_ADMIN_EMAIL=... ZAP_ADMIN_PASSWORD=YourPassword
ZAP_ADMIN_EMAIL=admin@example.com
ZAP_ADMIN_PASSWORD=ReplaceMe
